{
    "compilerOptions": {
        "types": [
            "node"
        ],
        "baseUrl": ".",
        "paths": {
            "@pages/*": [
                "tests/pages/*"
            ]
        },
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}